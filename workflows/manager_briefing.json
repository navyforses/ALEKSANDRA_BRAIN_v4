{
  "name": "manager-morning-briefing",
  "active": true,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 13 * * 0" }
          ]
        }
      },
      "name": "Sunday 13:00 UTC (09:00 ET)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300],
      "id": "trigger-sunday-briefing"
    },
    {
      "parameters": {
        "url": "={{ $env.PHASE5_MANAGER_WORKER_URL || $env.PHASE5_VOICE_WORKER_URL || 'https://placeholder.invalid' }}/morning-briefing",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "X-Auth-Token", "value": "={{ $env.PHASE5_WORKER_AUTH_TOKEN || '' }}" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"dry_run\": false, \"fired_at\": \"{{ $now.toISO() }}\" }",
        "options": { "timeout": 60000 }
      },
      "name": "Fire morning briefing",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300],
      "id": "fire-briefing",
      "onError": "continueRegularOutput",
      "notes": "Requires PHASE5_MANAGER_WORKER_URL env var on Railway. Until the Python manager worker is deployed, this node fails gracefully and the cron continues to fire every Sunday — operator notices the gap via /audit-log."
    },
    {
      "parameters": {
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/runs",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"kind\": \"manager_briefing_trigger\",\n  \"agent_id\": \"manager-briefing\",\n  \"exit_status\": \"queued\",\n  \"start_time\": \"{{ $now.toISO() }}\",\n  \"end_time\": \"{{ $now.toISO() }}\",\n  \"token_cost\": 0\n}",
        "options": {}
      },
      "name": "Log briefing trigger",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "id": "log-briefing-trigger"
    }
  ],
  "connections": {
    "Sunday 13:00 UTC (09:00 ET)": {
      "main": [[{ "node": "Fire morning briefing", "type": "main", "index": 0 }]]
    },
    "Fire morning briefing": {
      "main": [[{ "node": "Log briefing trigger", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "meta": {
    "description": "Phase 5 MNG-10 — Sunday 09:00 ET morning briefing. Fires the Python manager worker which calls scripts.manager.briefing.run() to compose a 3-bullet <=50 word Telegram message. Pure-n8n fallback writes a runs row so operator can detect a missed firing even when the worker is offline.",
    "phase": 5,
    "requirement": "MNG-10",
    "owner_locked": "Sundays 09:00 local (ET while in Boston/Durham)"
  }
}
