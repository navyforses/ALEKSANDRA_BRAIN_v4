# ═══════════════════════════════════════════════════════════
# ALEKSANDRA_BRAIN — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────
# Supabase (PostgreSQL + RLS)
# https://supabase.com/dashboard → Settings → API
# ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Public (frontend, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct DB connection string (for psql migrations)
# Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# ─────────────────────────────────────────────────
# Neo4j AuraDB (Knowledge Graph)
# https://console.neo4j.io
# ─────────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ─────────────────────────────────────────────────
# Qdrant (Vector Store)
# Local Docker by default; cloud optional
# ─────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─────────────────────────────────────────────────
# Cloudflare R2 (object storage)
# https://dash.cloudflare.com
# KV deprecated 2026-05-21 — Postgres absorbed dedup + budget + state roles.
# ─────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=aleksandra-brain-storage

# ─────────────────────────────────────────────────
# Anthropic (Claude API)
# https://console.anthropic.com
# ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-

# ─────────────────────────────────────────────────
# Telegram (Bot + Group Chat)
# https://t.me/BotFather
# ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────
# n8n (Automation)
# Railway-deployed instance
# ─────────────────────────────────────────────────
N8N_URL=https://xxxx.railway.app
N8N_API_KEY=

# ─────────────────────────────────────────────────
# Phase 0 — kill-switch + daily budget gate (FND-03, FND-04)
# ─────────────────────────────────────────────────
# Optional — Admin key for Anthropic Usage API.
# NO LONGER REQUIRED. Phase 0 budget gate now reads from Supabase `runs` table
# (token_cost summed per agent_run/fire_drill/llm_call), avoiding the need for a second
# Anthropic key. Leave empty unless you specifically want to add Usage API checks
# as an additional layer.
ANTHROPIC_USAGE_API_KEY=

# Hard daily ceiling in USD before n8n locks Anthropic-calling workflows
DAILY_BUDGET_USD=1.50

# Webhook URL n8n exposes for `panic_stop` to deactivate workflows
# (filled after n8n is deployed in workflows/daily-budget-gate.json)
PANIC_STOP_WEBHOOK_URL=

# ─────────────────────────────────────────────────
# Optional API keys (for specific MCPs)
# ─────────────────────────────────────────────────
FIRECRAWL_API_KEY=
PERPLEXITY_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=
OPENAI_API_KEY=        # only if needed; default is fastembed local

# ─────────────────────────────────────────────────
# Notion family knowledge base (Phase 4 ACD-04)
# https://www.notion.so/profile/integrations
# See docs/RUNBOOK-notion-api.md for one-time setup.
# Integration must have only Read/Insert/Update capabilities, connected
# to the single parent page below.
# ─────────────────────────────────────────────────
NOTION_API_KEY=                  # ntn_… or secret_…
NOTION_PARENT_PAGE_ID=           # 32-char hex from the parent page URL
NOTION_DATABASE_ID=              # set after running scripts/notion_bootstrap.py

# ─────────────────────────────────────────────────
# Phase 1 — Perception layer (PRC-01 … PRC-05)
# ─────────────────────────────────────────────────
# NCBI E-utilities — required for PRC-01 (PubMed). Register a free
# API key at https://www.ncbi.nlm.nih.gov/account/settings/ → API Key
# Management. With a key, NCBI allows 10 req/sec instead of 3.
NCBI_API_KEY=
NCBI_EMAIL=you@example.com
NCBI_TOOL=aleksandra_brain

# Firecrawl monthly spend ceiling in USD (PRC-05).
# Firecrawl only fires when Crawl4AI fails twice AND current-month
# spend (tracked in Supabase runs.cost_usd ledger) is below this cap.
FIRECRAWL_MONTHLY_CAP_USD=10

# ─────────────────────────────────────────────────
# GitHub (for self-hosted MCPs)
# ─────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_OWNER=navyforses
GITHUB_REPO=ALEKSANDRA_BRAIN_v4
